# Backend API base URL (no trailing slash)
# Local dev: http://localhost:4200
# Production: https://your-backend.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:4200

# ---- Test / CI only (not needed in production) ----
APPLITOOLS_API_KEY=<your-applitools-api-key>
SELENIUM_USERNAME=<selenium-username>
SELENIUM_PASSWORD=<selenium-password>
