{
    "name": "frontend",
    "version": "1.0.0",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "coverage": "jest --coverage",
        "cypress": "cypress open",
        "cypress:run": "cypress run",
        "format": "pnpm prettier && pnpm lint:fix",
        "lint": "node --no-deprecation ./node_modules/eslint/bin/eslint.js --max-warnings=0 --no-error-on-unmatched-pattern ./src",
        "lint:fix": "pnpm lint --fix",
        "prettier": "npx prettier ./src --write",
        "test": "jest",
        "selenium": "jest --config jest.selenium.config.js",
        "test:all": "pnpm test && pnpm cypress:run",
        "test:changed": "jest --onlyChanged",
        "test:failing": "jest --onlyFailures",
        "test:update": "jest --updateSnapshot",
        "test:watch": "jest --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@emotion/cache": "^11.14.0",
        "@emotion/react": "^11.14.0",
        "@emotion/server": "^11.11.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.6",
        "@mui/material": "^7.3.6",
        "@reduxjs/toolkit": "^1.9.7",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "axios": "^1.13.2",
        "classnames": "^2.5.1",
        "date-fns": "^3.6.0",
        "lodash": "^4.17.21",
        "lodash.clonedeep": "^4.5.0",
        "next": "^14.2.35",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hot-toast": "^2.6.0",
        "react-redux": "^8.1.3",
        "redux": "^4.2.1",
        "sass": "^1.99.0"
    },
    "devDependencies": {
        "@applitools/eyes-selenium": "^4.82.41",
        "@babel/core": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "@babel/preset-react": "^7.28.5",
        "@eslint/compat": "^1.4.1",
        "@eslint/js": "^9.39.2",
        "@mui/codemod": "^7.3.6",
        "@next/eslint-plugin-next": "^16.2.6",
        "@testing-library/cypress": "^10.1.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^14.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^29.5.14",
        "@types/lodash": "^4.17.21",
        "@types/node": "^18.19.130",
        "@types/redux-mock-store": "^1.5.0",
        "@types/selenium-webdriver": "^4.35.5",
        "babel-jest": "^30.2.0",
        "cypress": "^15.8.1",
        "dotenv": "^17.4.2",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-compat": "^5.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^15.15.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.2.0",
        "next-router-mock": "^1.0.5",
        "prettier": "3.3.2",
        "redux-mock-store": "^1.5.5",
        "redux-thunk": "^2.4.2",
        "rimraf": "^5.0.10",
        "selenium-webdriver": "^4.44.0",
        "ts-jest": "^29.4.6",
        "typescript": "^5.5.4",
        "typescript-eslint": "^7.18.0"
    },
    "pnpm": {
        "overrides": {
            "@babel/runtime": ">=7.26.10",
            "@types/react": ">=18",
            "@types/react-dom": ">=18"
        }
    }
}
